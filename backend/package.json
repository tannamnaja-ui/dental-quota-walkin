{
  "name": "dental-quota-walkin-backend",
  "version": "1.0.0",
  "description": "Dental Department Walk-in Quota Management System - Backend API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "pkg": "pkg . --target node18-win-x64 --output ../build/install_files/dental-quota-walkin.exe"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "scripts": [
      "src/**/*.js"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mysql2": "^3.22.3",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0",
    "nodemon": "^3.1.4"
  }
}
